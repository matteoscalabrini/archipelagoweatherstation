WEATHER_STATION_API_KEY=replace-with-a-long-random-token

# Optional but recommended on Vercel for persistent latest telemetry storage.
# Add a Redis/Upstash integration from the Vercel Marketplace.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV integrations may create these names instead.
# The app accepts either this pair or the UPSTASH_REDIS_* pair above.
KV_REST_API_URL=
KV_REST_API_TOKEN=
